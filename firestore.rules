rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSupportChatOwner(chatId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/support_chats/$(chatId)).data.userId == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
    
    // Interviews collection (new structure for NLP evaluation)
    match /interviews/{interviewId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Attempts subcollection
      match /attempts/{attemptId} {
        allow read, create, update: if isSignedIn() && (
          get(/databases/$(database)/documents/interviews/$(interviewId)).data.userId == request.auth.uid
          || isAdmin()
        );
      }
    }
    
    // Questions cache collection (for embeddings)
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write
    }

    // Final interview result documents
    match /interview_result/{resultId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || request.resource.data.userId == request.auth.uid
        || isAdmin()
      );
    }

    match /resources/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /job_suggestions/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /support_tickets/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // New one-to-one support chat system
    match /support_chats/{chatId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn() && (
        isAdmin() || (
          request.resource.data.userId == request.auth.uid
          && request.resource.data.chatId == chatId
        )
      );

      allow update: if isSignedIn() && (
        isAdmin() || resource.data.userId == request.auth.uid
      );

      match /messages/{messageId} {
        allow read: if isSignedIn() && (isSupportChatOwner(chatId) || isAdmin());

        allow create: if isSignedIn() && (
          (
            isAdmin()
            && request.resource.data.senderId == request.auth.uid
            && request.resource.data.senderRole == 'admin'
          ) || (
            isSupportChatOwner(chatId)
            && request.resource.data.senderId == request.auth.uid
            && request.resource.data.senderRole == 'user'
          )
        );

        allow update: if isSignedIn() && (
          isAdmin() ||
          (
            isSupportChatOwner(chatId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead', 'readAt'])
          )
        );
      }
    }

    match /admin_notifications/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /admin_activity_logs/{docId} {
      allow read, write: if isAdmin();
    }

    match /admin_settings/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
